			"\t\tlong double h=(b-a)/N_even;",
			"\t\tlong double sum=f(a)+f(b);",
			"\t\tfor(unsigned long long i=1;i<N_even;i++){",
			"\t\t\tlong double x=a+i*h;",
			"\t\t\tif(i&1)sum+=4.0l*f(x);",
			"\t\t\telse sum+=2.0l*f(x);",
			"\t\t}",
			"\t\treturn sum*h/3.0l;",
			"\t}",
			"}",
